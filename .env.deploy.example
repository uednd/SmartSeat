# SmartSeat single-host deployment template.
# Copy this file to .env.deploy and replace every replace-with-* value before running docker:* commands.
# .env.deploy is ignored by git. Do not commit real secrets.

COMPOSE_PROJECT_NAME=smartseat
SMARTSEAT_API_IMAGE=smartseat-api:local
SMARTSEAT_API_PORT=3000
SMARTSEAT_POSTGRES_PORT=5432
SMARTSEAT_MQTT_PORT=1883

NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=3000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=smartseat_deploy
POSTGRES_USER=smartseat_deploy
POSTGRES_PASSWORD=replace-with-strong-database-password
DATABASE_URL=postgresql://smartseat_deploy:replace-with-strong-database-password@postgres:5432/smartseat_deploy

MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=replace-with-mqtt-username
MQTT_PASSWORD=replace-with-mqtt-password
MQTT_ENABLED=true
MQTT_BROKER_URL=mqtt://mosquitto:1883
MQTT_CLIENT_ID=smartseat-api-deploy
MQTT_HEARTBEAT_OFFLINE_THRESHOLD_SECONDS=75
PRESENCE_PRESENT_STABLE_SECONDS=60
PRESENCE_ABSENT_STABLE_SECONDS=300
PRESENCE_UNTRUSTED_STABLE_SECONDS=120
PRESENCE_EVALUATION_ENABLED=true
AUTO_RULES_ENABLED=true
AUTO_RULES_NO_SHOW_ENABLED=true
AUTO_RULES_USAGE_ENABLED=true
AUTO_RULES_OCCUPANCY_ANOMALIES_ENABLED=true
AUTO_RULES_DEVICE_RECONCILE_ENABLED=true
AUTO_RULES_SENSOR_ERROR_ENABLED=true
AUTO_RULES_NO_SHOW_INTERVAL_SECONDS=30
AUTO_RULES_USAGE_INTERVAL_SECONDS=30
AUTO_RULES_OCCUPANCY_ANOMALY_INTERVAL_SECONDS=30
AUTO_RULES_DEVICE_RECONCILE_INTERVAL_SECONDS=15
AUTO_RULES_ENDING_SOON_WINDOW_SECONDS=600
ANOMALY_IDLE_PRESENT_STABLE_SECONDS=60
ANOMALY_OCCUPIED_ABSENT_STABLE_SECONDS=300
ANOMALY_OVERTIME_PRESENT_STABLE_SECONDS=60
ANOMALY_SENSOR_ERROR_STABLE_SECONDS=120

QR_TOKEN_REFRESH_SECONDS=15
QR_TOKEN_TTL_SECONDS=30
CHECKIN_ENABLED=true

WECHAT_APP_ID=replace-with-wechat-app-id-or-disabled-value
WECHAT_APP_SECRET=replace-with-wechat-secret-or-disabled-value
WECHAT_AUTH_PROVIDER_MODE=mock
OIDC_ISSUER=https://replace-with-oidc-issuer.invalid
OIDC_CLIENT_ID=replace-with-oidc-client-id-or-disabled-value
OIDC_CLIENT_SECRET=replace-with-oidc-client-secret-or-disabled-value
OIDC_REDIRECT_URI=https://replace-with-api-origin.invalid/auth/oidc/callback
OIDC_AUTH_PROVIDER_MODE=mock

AUTH_TOKEN_SECRET=replace-with-strong-auth-token-secret
AUTH_TOKEN_TTL_SECONDS=3600
DEFAULT_AUTH_MODE=WECHAT
