{
  "name": "smartseat",
  "version": "0.0.0",
  "private": true,
  "description": "SmartSeat campus library seat-management prototype monorepo.",
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "db:generate": "pnpm --filter @smartseat/api db:generate",
    "db:migrate": "pnpm --filter @smartseat/api db:migrate",
    "db:migrate:dev": "pnpm --filter @smartseat/api db:migrate:dev",
    "db:reset-demo": "pnpm --filter @smartseat/api db:reset-demo",
    "db:seed": "pnpm --filter @smartseat/api db:seed",
    "dev:api": "pnpm --filter @smartseat/api dev",
    "dev:sim": "pnpm --filter @smartseat/device-simulator dev",
    "docker:build": "docker compose --env-file .env.deploy -f infra/docker-compose.deploy.yml build",
    "docker:config": "docker compose --env-file .env.deploy -f infra/docker-compose.deploy.yml config",
    "docker:down": "docker compose --env-file .env.deploy -f infra/docker-compose.deploy.yml down",
    "docker:logs": "docker compose --env-file .env.deploy -f infra/docker-compose.deploy.yml logs -f api",
    "docker:ps": "docker compose --env-file .env.deploy -f infra/docker-compose.deploy.yml ps",
    "docker:up": "docker compose --env-file .env.deploy -f infra/docker-compose.deploy.yml up -d --build",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "prettier --check .",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^24.0.0",
    "eslint": "^9.25.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1"
  }
}
