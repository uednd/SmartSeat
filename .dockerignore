.DS_Store

# Environment and secrets
.env
.env.*
!.env.example
!.env.deploy.example

# Git and editor metadata
.git/
.gitignore
.idea/
.vscode/
*.swp

# Dependencies and package-manager caches
node_modules/
.pnpm-store/

# Build/test outputs
dist/
build/
coverage/
.turbo/
.cache/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local infrastructure data
infra/postgres-data/
infra/mosquitto/data/
infra/mosquitto/log/

# ESP-IDF generated output
firmware/**/build/
firmware/**/sdkconfig
firmware/**/sdkconfig.old
