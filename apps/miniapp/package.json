{
  "name": "@smartseat/miniapp",
  "version": "0.0.0",
  "private": true,
  "description": "SmartSeat uni-app mini program shell with shared login and role routing.",
  "scripts": {
    "dev": "uni -p mp-weixin",
    "dev:h5": "uni",
    "dev:mp-weixin": "uni -p mp-weixin",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build -p mp-weixin",
    "lint": "eslint vite.config.ts shims-uni.d.ts src --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-components": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-h5": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5000820260430001",
    "@smartseat/api-client": "workspace:*",
    "@smartseat/contracts": "workspace:*",
    "vue": "3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.31",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5000820260430001",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "^5.8.3",
    "vite": "5.2.8",
    "vitest": "^1.6.1",
    "vue-tsc": "^3.2.8"
  }
}
